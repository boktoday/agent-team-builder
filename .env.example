# =============================================================================
# Agent Team Builder - Environment Variables Template
# =============================================================================
# Copy this file to .env.local for local development
# Copy to .env.example for your exported agent repos
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Production only)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# OpenRouter.ai - Unified API for 100+ AI Models
# -----------------------------------------------------------------------------
# Get your key: https://openrouter.ai/settings/keys
# Docs: https://openrouter.ai/docs
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Venice AI - Uncensored AI Models & Image Generation
# -----------------------------------------------------------------------------
# Get your key: https://docs.venice.ai/api-keys
# Docs: https://docs.venice.ai
VENICE_API_KEY=venice-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Mason AI - Coding & Development AI
# -----------------------------------------------------------------------------
# Get your key: https://mason.ai/dashboard/api-keys
# Docs: https://mason.ai/docs
MASON_API_KEY=mason_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Skillboss.co - Expert AI Agents for Business
# -----------------------------------------------------------------------------
# Get your key: https://skillboss.co/dashboard
# Docs: https://skillboss.co/docs
SKILLBOSS_API_KEY=sb_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# OpenAI (Optional - if not using OpenRouter)
# -----------------------------------------------------------------------------
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Anthropic Claude (Optional)
# -----------------------------------------------------------------------------
# Get your key: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Default Model Configuration
# -----------------------------------------------------------------------------
# Choose your default provider: openrouter, openai, anthropic, venice, mason, skillboss
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=gpt-4

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
NODE_ENV=development
